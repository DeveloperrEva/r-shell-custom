{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "r-shell",
  "version": "2.5.3",
  "identifier": "com.aiden.r-shell",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "r-shell",
        "width": 1920,
        "height": 1080,
        "fullscreen": false,
        "maximized": true,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/DeveloperrEva/r-shell-custom/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwRDhBMkYzMEJBNDg2NEQKUldSTmhxUUw4NkxZOEcwTmJrdEM2cGVjWVF1NDY1Z00wYkozbmVhQ25mckJKR2NFcEtFMVpFK2QK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
